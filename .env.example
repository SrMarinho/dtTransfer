# =============================================================================
# Engine global
# =============================================================================
LOG_LEVEL = INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Diretório externo de workspaces (opcional). Workspaces aqui se somam aos
# built-in em src/workspaces/.
# WORKSPACES_DIR = /data/workspaces

# Telegram — notificações automáticas de erro (opcional)
TELEGRAM_BOT_TOKEN   =
TELEGRAM_CHAT_ID     =
BOT_GROUP_CHAT_ID    =


# =============================================================================
# Workspace: biMktNaz (legado)
# Source: PBS Nazaria (SQL Server) → Target: biMktNaz (Postgres)
# =============================================================================
DB_NAZARIA_SQLSERVER_HOST     = 127.0.0.1
DB_NAZARIA_SQLSERVER_PORT     = 1433
DB_NAZARIA_SQLSERVER_DATABASE = database
DB_NAZARIA_SQLSERVER_USERNAME = username
DB_NAZARIA_SQLSERVER_PASSWORD = password

DB_BIMKTNAZ_POSTGRES_HOST     = 127.0.0.1
DB_BIMKTNAZ_POSTGRES_PORT     = 5432
DB_BIMKTNAZ_POSTGRES_DATABASE = database
DB_BIMKTNAZ_POSTGRES_USERNAME = username
DB_BIMKTNAZ_POSTGRES_PASSWORD = password


# =============================================================================
# Workspace: biSenior (legado)
# Source: Senior (Oracle) → Target: biSenior (Postgres)
# =============================================================================
DB_SENIOR_ORACLE_SERVICE_NAME = 127.0.0.1
DB_SENIOR_ORACLE_USER         = user
DB_SENIOR_ORACLE_PASSWORD     = password
DB_SENIOR_ORACLE_HOST         = host
DB_SENIOR_ORACLE_PORT         = 1521
DB_SENIOR_ORACLE_ENCODING     = utf8

DB_BISENIOR_POSTGRES_HOST     = 127.0.0.1
DB_BISENIOR_POSTGRES_PORT     = 5432
DB_BISENIOR_POSTGRES_DATABASE = database
DB_BISENIOR_POSTGRES_USERNAME = postgres
DB_BISENIOR_POSTGRES_PASSWORD = admin


# =============================================================================
# Workspace: biNazaria (legado)
# Source: PBS Nazaria (SQL Server, mesma do biMktNaz) → Target: biNazaria (Postgres)
# =============================================================================
DB_BINAZARIA_POSTGRES_HOST     = 127.0.0.1
DB_BINAZARIA_POSTGRES_PORT     = 5432
DB_BINAZARIA_POSTGRES_DATABASE = database
DB_BINAZARIA_POSTGRES_USERNAME = username
DB_BINAZARIA_POSTGRES_PASSWORD = password


# =============================================================================
# Workspace: example (template SQLite)
# =============================================================================
DB_EXAMPLE_SQLITE_DATABASE        = /tmp/example.db
DB_EXAMPLE_SOURCE_SQLITE_DATABASE = /tmp/example_source.db