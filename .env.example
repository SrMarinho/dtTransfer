# =============================================================================
# Global engine settings
# =============================================================================
LOG_LEVEL = INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# External workspaces directory (optional). Merged with built-in src/workspaces/.
# WORKSPACES_DIR = /data/workspaces

# Telegram — automatic error notifications (optional)
TELEGRAM_BOT_TOKEN   =
TELEGRAM_CHAT_ID     =
BOT_GROUP_CHAT_ID    =


# =============================================================================
# Example workspace (SQLite)
# =============================================================================
DB_EXAMPLE_SQLITE_DATABASE        = /tmp/example.db
DB_EXAMPLE_SOURCE_SQLITE_DATABASE = /tmp/example_source.db


# =============================================================================
# Database connection templates
# =============================================================================
# Each workspace defines its own env_prefix. Variables are resolved as:
#   {ENV_PREFIX}_HOST
#   {ENV_PREFIX}_PORT
#   {ENV_PREFIX}_DATABASE
#   {ENV_PREFIX}_USERNAME
#   {ENV_PREFIX}_PASSWORD
#
# Example for a PostgreSQL workspace with env_prefix "DB_MYAPP":
#
# DB_MYAPP_HOST     = 127.0.0.1
# DB_MYAPP_PORT     = 5432
# DB_MYAPP_DATABASE = mydb
# DB_MYAPP_USERNAME = user
# DB_MYAPP_PASSWORD = secret
#
# Example for a SQL Server workspace:
#
# DB_ERP_HOST     = 192.168.1.100
# DB_ERP_PORT     = 1433
# DB_ERP_DATABASE = erp_db
# DB_ERP_USERNAME = sa
# DB_ERP_PASSWORD = secret
#
# Example for an Oracle workspace:
#
# DB_ORACLE_HOST         = 10.0.0.50
# DB_ORACLE_PORT         = 1521
# DB_ORACLE_SERVICE_NAME = XEPDB1
# DB_ORACLE_USER         = system
# DB_ORACLE_PASSWORD     = secret
# DB_ORACLE_ENCODING     = utf8
#
# See src/core/databases/connections/ for driver-specific options.
